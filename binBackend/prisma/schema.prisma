generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum bin_status {
  FULL
  NORMAL
}

enum complaint_status {
  OPEN
  CLOSED
}

enum alert_status {
  PENDING
  RESOLVED
}

model Location {
  location_id Int    @id @default(autoincrement())
  area_name   String
  latitude    Decimal @db.Decimal(10, 7)
  longitude   Decimal @db.Decimal(10, 7)

  bins Bin[]

  @@map("locations")
}

model Bin {
  bin_id        Int        @id @default(autoincrement())
  location_id   Int
  capacity      Int
  current_fill  Int
  status        bin_status
  last_updated  DateTime   @db.Timestamp(6)

  location      Location   @relation(fields: [location_id], references: [location_id], onDelete: Restrict, onUpdate: Cascade)
  sensor_data   SensorData[]
  collections   Collection[]
  complaints    Complaint[]
  alerts        Alert[]

  @@index([location_id])
  @@map("bins")
}

model SensorData {
  sensor_id    Int      @id @default(autoincrement())
  bin_id       Int
  fill_level   Int
  temperature  Decimal  @db.Decimal(6, 2)
  gas_level    Decimal  @db.Decimal(6, 2)
  status       String
  timestamp    DateTime @db.Timestamp(6)

  bin          Bin      @relation(fields: [bin_id], references: [bin_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([bin_id])
  @@index([timestamp])
  @@map("sensor_data")
}

model Alert {
  alert_id     Int          @id @default(autoincrement())
  bin_id       Int
  status       alert_status @default(PENDING)
  message      String
  created_at   DateTime     @default(now()) @db.Timestamp(6)

  bin          Bin          @relation(fields: [bin_id], references: [bin_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([bin_id])
  @@index([status])
  @@map("alerts")
}

model Vehicle {
  vehicle_id    Int      @id @default(autoincrement())
  vehicle_type  String
  capacity      Int
  is_ev         Boolean
  status        String

  drivers       Driver[]
  routes        Route[]

  @@map("vehicles")
}

model Driver {
  driver_id       Int      @id @default(autoincrement())
  name            String
  phone           String
  license_number  String
  vehicle_id      Int

  vehicle         Vehicle  @relation(fields: [vehicle_id], references: [vehicle_id], onDelete: Restrict, onUpdate: Cascade)
  routes          Route[]

  @@unique([vehicle_id])
  @@index([vehicle_id])
  @@map("drivers")
}

model Route {
  route_id         Int          @id @default(autoincrement())
  vehicle_id       Int
  driver_id        Int
  total_distance   Decimal      @db.Decimal(10, 2)
  created_at       DateTime     @default(now()) @db.Timestamp(6)

  vehicle          Vehicle      @relation(fields: [vehicle_id], references: [vehicle_id], onDelete: Restrict, onUpdate: Cascade)
  driver           Driver       @relation(fields: [driver_id], references: [driver_id], onDelete: Restrict, onUpdate: Cascade)
  collections      Collection[]

  @@index([vehicle_id])
  @@index([driver_id])
  @@map("routes")
}

model Collection {
  collection_id       Int      @id @default(autoincrement())
  route_id            Int
  bin_id              Int
  collected_at        DateTime @default(now()) @db.Timestamp(6)
  fill_level_before   Int

  route               Route    @relation(fields: [route_id], references: [route_id], onDelete: Restrict, onUpdate: Cascade)
  bin                 Bin      @relation(fields: [bin_id], references: [bin_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([route_id])
  @@index([bin_id])
  @@index([collected_at])
  @@map("collections")
}

model Complaint {
  complaint_id   Int              @id @default(autoincrement())
  bin_id         Int
  reported_by    String
  description    String
  image_path     String?
  status         complaint_status @default(OPEN)
  created_at     DateTime         @default(now()) @db.Timestamp(6)

  bin            Bin              @relation(fields: [bin_id], references: [bin_id], onDelete: Restrict, onUpdate: Cascade)

  @@index([bin_id])
  @@index([status])
  @@map("complaints")
}

model User {
  user_id        Int      @id @default(autoincrement())
  email          String   @unique
  password_hash  String
  role           String   @default("admin")
  created_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("users")
}
